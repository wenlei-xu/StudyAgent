# ── LLM ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# 路由/出题用强模型，讲解用性价比模型
SUPERVISOR_MODEL=gpt-4o
EXPLAINER_MODEL=gpt-4o-mini
QUIZZER_MODEL=gpt-4o
CHECKER_MODEL=gpt-4o-mini
RECOMMENDER_MODEL=gpt-4o-mini

# ── Embedding ──
EMBEDDING_MODEL=text-embedding-3-small

# ── Database ──
DATABASE_URL=postgresql+asyncpg://agent:agent123@localhost:5432/agent_learning
DATABASE_URL_SYNC=postgresql+psycopg2://agent:agent123@localhost:5432/agent_learning

# ── Tavily Search ──
TAVILY_API_KEY=tvly-your-key-here

# ── App ──
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
